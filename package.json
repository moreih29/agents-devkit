{
  "name": "claude-nexus",
  "version": "0.28.1",
  "type": "module",
  "description": "Agent orchestration plugin for Claude Code — optimized context injection per role",
  "author": "kih",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moreih29/claude-nexus.git"
  },
  "homepage": "https://github.com/moreih29/claude-nexus#readme",
  "bugs": {
    "url": "https://github.com/moreih29/claude-nexus/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run sync",
    "sync": "bunx @moreih29/nexus-core sync --harness=claude --target=./",
    "sync:dry": "bunx @moreih29/nexus-core sync --harness=claude --target=./ --dry-run",
    "validate": "bunx @moreih29/nexus-core validate",
    "list": "bunx @moreih29/nexus-core list",
    "test": "bash test/e2e.sh"
  },
  "files": [
    "agents",
    "skills",
    "hooks",
    "dist/hooks",
    "scripts",
    ".claude-plugin",
    ".mcp.json",
    "settings.json",
    "VERSION"
  ],
  "devDependencies": {
    "@moreih29/nexus-core": "^0.15.1"
  },
  "dependencies": {}
}
